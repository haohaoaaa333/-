ADMIN_OPENIDS=openid-of-bootstrap-super-admin
ADMIN_SECRET=temporary-legacy-secret
ADMIN_ALLOWED_ORIGINS=http://127.0.0.1:8787,http://localhost:8787

# 草稿箱 AI 审核（免费 hy3 / HunYuan）配置。
# aiStruct 与 admin 共用同一套 env 的免费 AI 网关，无需任何 API Key。
# 默认走 hunyuan-v3 provider + hy3 模型（小程序成长计划免费额度）。
AI_PROVIDER=hunyuan-v3
AI_MODEL=hy3
