# ── Worker 身份 ──
# 必须与 workerGateway 云函数的环境变量 WORKER_SECRET 完全一致
WORKER_ID=worker-rtx5070-01
WORKER_SECRET=__换成与 workerGateway 相同的密钥（>=24 位）__

# 管理 admin 云函数 ADMIN_SECRET（Worker 以受信服务端身份创建/追加草稿）
ADMIN_SECRET=__与管理 admin 云函数 ADMIN_SECRET 一致__

# ── 云函数端点 ──
# workerGateway 云函数 HTTP 地址
WORKER_GATEWAY_URL=https://your-env.apigw.tencentcs.com/release/workerGateway
# admin 云函数 HTTP 地址（与 admin 前端连接设置里的地址一致）
ADMIN_URL=https://your-env.apigw.tencentcs.com/release/admin

# ── 节奏（毫秒）──
WORKER_POLL_INTERVAL_MS=5000
WORKER_HEARTBEAT_INTERVAL_MS=15000
WORKER_MINERU_POLL_MS=4000
WORKER_LEASE_BUFFER_MS=30000

# 单 GPU 并发固定为 1，勿改
WORKER_CONCURRENCY=1
WORKER_SINGLE_PROCESS_LOCK=true

# ── MinerU / Python ──
# PYTHON=python3
# MINERU_COMMAND=mineru
# MINERU_PYTHON=/path/to/miniconda3/envs/mineru/python.exe
MINERU_BACKEND=pipeline

# ── 存储后端 ──
# tcb   ：腾讯云 CloudBase Node SDK（生产，需下方 TCB_* 凭证）
# local ：本地镜像目录（离线测试 / 无云环境，把 cloud:// 映射到本地文件）
WORKER_STORAGE_BACKEND=tcb
CLOUD_MIRROR_DIR=run/cloud-mirror

# TCB 凭证（仅 tcb 后端需要）
TCB_ENV_ID=your-env-id
TCB_SECRET_ID=__腾讯云 SecretId__
TCB_SECRET_KEY=__腾讯云 SecretKey__
# TCB_ENV_TYPE=non-shared

# 调试
# WORKER_DRY_RUN=false
