{
  "name": "examprep-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "考公宝 - 公务员考试刷题小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "clean:generated": "node scripts/cleanup_generated_files.js",
    "clean:generated:dry": "node scripts/cleanup_generated_files.js --dry-run",
    "build:weapp": "npx taro build --type weapp",
    "build:weapp:quality": "npm run build:weapp && npm run quality:weapp",
    "quality:weapp": "node scripts/check_miniprogram_quality.js",
    "build:h5": "npx taro build --type h5",
    "build:tt": "npx taro build --type tt",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "author": "",
  "dependencies": {
    "@tarojs/components": "^4.0.13",
    "@tarojs/helper": "^4.0.13",
    "@tarojs/plugin-platform-h5": "^4.0.13",
    "@tarojs/plugin-platform-weapp": "^4.0.13",
    "@tarojs/react": "^4.0.13",
    "@tarojs/runtime": "^4.0.13",
    "@tarojs/shared": "^4.0.13",
    "@tarojs/taro": "^4.0.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
    "@tarojs/cli": "^4.2.0",
    "@tarojs/plugin-framework-react": "^4.2.0",
    "@tarojs/webpack5-runner": "^4.0.13",
    "@types/react": "^18.3.0",
    "babel-loader": "^9.1.3",
    "babel-preset-taro": "^4.0.13",
    "postcss": "^8.4.40",
    "react-refresh": "^0.14.2",
    "sass": "^1.80.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0"
  }
}
